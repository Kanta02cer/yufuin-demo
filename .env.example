# APIキー・設定のテンプレート。
# このファイルをコピーして .env を作成し、実際の値を入れてください。
#   cp .env.example .env
# .env は .gitignore 済みで Git にはコミットされません（キーは絶対に直書きしない）。
# 本番(GitHub Actions)では、これらを Settings → Secrets and variables → Actions に
# 登録します（下記 README 参照）。値は空のままでも各ソースは安全に無効化されます。

# ── Booking.com (RapidAPI: booking-com15) ──
RAPIDAPI_KEY=
# BOOKING_HORIZON_DAYS=30

# ── 楽天トラベル公式API ──
RAKUTEN_APP_ID=
RAKUTEN_ACCESS_KEY=
# 2026年新仕様: Allowed websites に登録したドメインと一致させる
RAKUTEN_REFERER=https://kanta02cer.github.io/
RAKUTEN_ORIGIN=https://kanta02cer.github.io

# ── SerpAPI (Google Hotels) ──
SERPAPI_KEY=
# SERPAPI_HORIZON_DAYS=30

# ── Slack 通知（任意） ──
SLACK_WEBHOOK_URL=

# ── 監視パラメータ（任意・上書き用） ──
# ALERT_THRESHOLD=0.05
# HORIZON_DAYS=180
